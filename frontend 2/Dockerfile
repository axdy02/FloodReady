FROM node:24.18.0-bookworm-slim@sha256:cb4e8f7c443347358b7875e717c29e27bf9befc8f5a26cf18af3c3dec80e58c5 AS dependencies
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM dependencies AS build
WORKDIR /app
ARG FRONTEND_ENV
ARG NEXT_PUBLIC_API_BASE_URL
ARG INTERNAL_API_BASE_URL
ARG NEXT_PUBLIC_APP_ORIGIN
ARG NEXT_PUBLIC_MAP_STYLE_URL
ARG NEXT_PUBLIC_MAP_ATTRIBUTION
ARG NEXT_PUBLIC_MAP_CONNECT_ORIGINS
ARG NEXT_PUBLIC_MAP_IMAGE_ORIGINS
ARG NEXT_PUBLIC_DEFAULT_MAP_LATITUDE
ARG NEXT_PUBLIC_DEFAULT_MAP_LONGITUDE
ARG NEXT_PUBLIC_DEFAULT_MAP_ZOOM
ARG NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB
ENV FRONTEND_ENV=$FRONTEND_ENV
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV INTERNAL_API_BASE_URL=$INTERNAL_API_BASE_URL
ENV NEXT_PUBLIC_APP_ORIGIN=$NEXT_PUBLIC_APP_ORIGIN
ENV NEXT_PUBLIC_MAP_STYLE_URL=$NEXT_PUBLIC_MAP_STYLE_URL
ENV NEXT_PUBLIC_MAP_ATTRIBUTION=$NEXT_PUBLIC_MAP_ATTRIBUTION
ENV NEXT_PUBLIC_MAP_CONNECT_ORIGINS=$NEXT_PUBLIC_MAP_CONNECT_ORIGINS
ENV NEXT_PUBLIC_MAP_IMAGE_ORIGINS=$NEXT_PUBLIC_MAP_IMAGE_ORIGINS
ENV NEXT_PUBLIC_DEFAULT_MAP_LATITUDE=$NEXT_PUBLIC_DEFAULT_MAP_LATITUDE
ENV NEXT_PUBLIC_DEFAULT_MAP_LONGITUDE=$NEXT_PUBLIC_DEFAULT_MAP_LONGITUDE
ENV NEXT_PUBLIC_DEFAULT_MAP_ZOOM=$NEXT_PUBLIC_DEFAULT_MAP_ZOOM
ENV NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=$NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB
COPY . .
RUN npm run build

FROM node:24.18.0-bookworm-slim@sha256:cb4e8f7c443347358b7875e717c29e27bf9befc8f5a26cf18af3c3dec80e58c5 AS runtime
WORKDIR /app
RUN groupadd --gid 10001 floodready && useradd --uid 10001 --gid 10001 --create-home floodready
COPY --from=build --chown=10001:10001 /app/.next/standalone ./
COPY --from=build --chown=10001:10001 /app/.next/static ./.next/static
USER 10001:10001
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
EXPOSE 3000
HEALTHCHECK --interval=10s --timeout=3s --start-period=20s --retries=6 CMD node -e "fetch('http://127.0.0.1:3000/api/health').then((response) => process.exit(response.ok ? 0 : 1)).catch(() => process.exit(1))"
CMD ["node", "server.js"]
