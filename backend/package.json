{
  "name": "floodready-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings 0 --ignore-pattern dist-demo/**",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test-runner.mjs",
    "test:vitest": "vitest run",
    "test:watch": "node scripts/test-runner.mjs --watch",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:demo": "tsx prisma/demo-seed.ts",
    "build:demo-seed": "prisma generate && tsc -p tsconfig.demo-seed.json",
    "quality:source": "node scripts/check-source.mjs",
    "verify": "node scripts/acceptance.mjs --verify",
    "acceptance": "node scripts/acceptance.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "argon2": "0.44.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "file-type": "22.0.1",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "multer": "2.2.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.2.0",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "eslint": "10.6.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
